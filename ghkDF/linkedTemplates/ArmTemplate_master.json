{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ghkDF"
		},
		"AzureDataLakeStorage_csv_sink_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage_csv_sink'"
		},
		"AzureSqlDatabase_azuresqldb_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabase_azuresqldb'"
		},
		"AzureDataLakeStorage_csv_sink_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://ghklearnsadatalake.dfs.core.windows.net/"
		},
		"AzureSqlDatabase_azuresqldb_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "ghklearndbserver.database.windows.net"
		},
		"AzureSqlDatabase_azuresqldb_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "ghklearnsqldb"
		},
		"AzureSqlDatabase_azuresqldb_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "ghksqladmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ghkDF_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage_csv_sink_accountKey": {
						"value": "[parameters('AzureDataLakeStorage_csv_sink_accountKey')]"
					},
					"AzureSqlDatabase_azuresqldb_password": {
						"value": "[parameters('AzureSqlDatabase_azuresqldb_password')]"
					},
					"AzureDataLakeStorage_csv_sink_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage_csv_sink_properties_typeProperties_url')]"
					},
					"AzureSqlDatabase_azuresqldb_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase_azuresqldb_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase_azuresqldb_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase_azuresqldb_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase_azuresqldb_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase_azuresqldb_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}